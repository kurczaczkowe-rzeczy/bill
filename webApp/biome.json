{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*.{js,cjs,mjs,ts,mts,cts,vue,glsl,css}",
      "!.idea",
      "!.nuxt",
      "!.output",
      "!dist",
      "!node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentWidth": 2,
    "indentStyle": "space",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "expand": "auto",
    "attributePosition": "multiline",
    "formatWithErrors": true
  },
  "linter": {
    "enabled": true,
    "domains": {
      "vue": "all"
    },
    "rules": {
      "recommended": true,
      "correctness": {
        "recommended": true,
        "noUnusedFunctionParameters": {
          "level": "warn",
          "fix": "none",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "noUnusedVariables": {
          "fix": "none",
          "level": "warn",
          "options": {
            "ignoreRestSiblings": true
          }
        }
      },
      "style": {
        "recommended": true,
        "noNegationElse": "error",
        "noNestedTernary": "error",
        "useCollapsedIf": "error",
        "useCollapsedElseIf": "error",
        "useImportType": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":PACKAGE:", ":PACKAGE_WITH_PROTOCOL:"],
              ":BLANK_LINE:",
              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "enabled": true,
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "attributePosition": "multiline",
      "bracketSpacing": true,
      "operatorLinebreak": "before"
    },
    "assist": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    },
    "assist": {
      "enabled": true
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "indentStyle": "space",
      "lineWidth": 100,
      "attributePosition": "multiline",
      "selfCloseVoidElements": "always"
    },
    "linter": { "enabled": true },
    "assist": { "enabled": true }
  }
}
